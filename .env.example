# Kairos Studio — Environment variables
# Copy this file to .env.local and fill in real values. Never commit .env.local.

# --- Public site config ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CALENDLY_URL=
NEXT_PUBLIC_WHATSAPP_NUMBER=

# --- Nagi chat backend (server-only) ---
N8N_CHAT_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# --- Rate limiting (server-only, Upstash Redis) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Optional direct-LLM fallback (not consumed yet) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Analytics (optional, Phase 6) ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
